APP_NAME=Legal RAG API
APP_ENV=dev
API_PORT=8000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_rag
POSTGRES_USER=legal_rag
POSTGRES_PASSWORD=legal_rag
DATABASE_URL=postgresql+psycopg://legal_rag:legal_rag@localhost:5432/legal_rag

# Keep local model URLs configurable for Day 2+
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_CACHE_DIR=backend/.model_cache/sentence-transformers
GENERATION_BACKEND=ollama
GENERATION_MODEL=qwen2.5:7b-instruct
GENERATION_STRICT=true
QA_MIN_RETRIEVAL_SCORE=0.35
QA_FORCE_KEYWORD=material breach
QA_FORCE_MIN_SCORE=0.45
QA_MIN_LEXICAL_OVERLAP=0.2
QA_DIRECT_ANSWER_MIN_OVERLAP=0.4
